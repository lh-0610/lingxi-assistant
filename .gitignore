# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg

# ─── 打包产物 ───
dist/
build/
# PyInstaller 自动生成的 .spec 可能含本机路径，默认忽略；
# 但 lingxi.spec 是手维护的发布配置（已清洗，无本机路径），需要提交
*.spec
!lingxi.spec
*.exe

# ─── 编辑器 / IDE ───
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
# Claude Code 内部配置
.claude/

# ─── 备份 ───
*.bak
*.orig

# ─── 本应用：含密钥 / 个人数据 ───
# API 密钥
config.json
# 会话历史
chat_memory/
# 运行日志
logs/

# ─── 第三方版权资产（用户自行获取，不分发）───
# 桌宠立绘 / GIF / sprite（如二次元角色立绘，版权归原作者）
assets/desktop_pet/*.png
assets/desktop_pet/*.gif
assets/desktop_pet/*.jpg
assets/desktop_pet/*.webp
assets/desktop_pet/sprites/

# 角色卡（特定 IP，自行加入；example.md 例外保留作模板）
roles/*.md
!roles/example.md

# 临时输出
output/
tmp/
*.tmp
