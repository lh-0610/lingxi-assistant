    },
    "context7-sse": {
      "transport": "sse",
      "url": "http://localhost:8010/sse"
    },
    "my-server-streamable": {
      "transport": "streamable_http",
      "url": "http://127.0.0.1:8080/mcp"
    },
    "my-server-auto": {
      "transport": "auto",
      "url": "http://127.0.0.1:8080/mcp"
    }
  }
